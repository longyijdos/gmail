{
  "name": "@longyijdos/gmail",
  "version": "0.1.0",
  "description": "A Gmail CLI with concise text and optional JSON output for agents and scripts.",
  "type": "module",
  "bin": {
    "gml": "./dist/gml.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/main.ts --target=bun --outfile=dist/gml.js && chmod +x dist/gml.js",
    "check": "bun run typecheck && bun test",
    "prepack": "bun run check && bun run build",
    "typecheck": "tsc --noEmit",
    "dev": "bun src/main.ts"
  },
  "keywords": [
    "gmail",
    "cli",
    "oauth",
    "json",
    "agent",
    "automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "email-addresses": "^5.0.0",
    "p-limit": "^7.3.1"
  }
}
