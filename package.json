{
  "name": "@longyijdos/gmail",
  "version": "0.1.0",
  "description": "A Gmail CLI with concise text and optional JSON output for agents and scripts.",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "bin": {
    "gml": "./dist/gml.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=dist/gml.js && node -e \"require('node:fs').chmodSync('dist/gml.js', 0o755)\"",
    "check": "biome check . && npm run typecheck && npm test",
    "check:fix": "biome check --write . && npm run typecheck && npm test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepare": "husky",
    "prepack": "npm run check && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts"
  },
  "keywords": [
    "gmail",
    "cli",
    "oauth",
    "json",
    "agent",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longyijdos/gmail.git"
  },
  "homepage": "https://github.com/longyijdos/gmail#readme",
  "bugs": {
    "url": "https://github.com/longyijdos/gmail/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "22.20.1",
    "esbuild": "0.28.1",
    "husky": "9.1.7",
    "tsx": "4.23.1",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "email-addresses": "^5.0.0",
    "p-limit": "^7.3.1",
    "undici": "^7.28.0"
  }
}
